# 心语语言示例程序
# 演示内置函数的使用

定义 数字 = 42。
定义 文本 = "心语语言"。

# 打印基本值
打印 "数字: " + 转字符串(数字)。
打印 "文本: " + 文本。

# 数学运算
定义 数列 = [1, 2, 3, 4, 5]。
打印 "数列: " + 转字符串(数列)。
打印 "求和: " + 转字符串(求和 数列)。
打印 "最大值: " + 转字符串(最大值 数列)。
打印 "最小值: " + 转字符串(最小值 数列)。
打印 "长度: " + 转字符串(长度 数列)。

# 类型转换
定义 浮点数 = 转浮点 数字。
打印 "转浮点: " + 转字符串(浮点数)。

定义 绝对值结果 = 绝对值 -10。
打印 "绝对值(-10): " + 转字符串(绝对值结果)。

打印 "程序执行完成！"。
