# 心语编程语言 - 条件判断示例

# 简单条件
定 x = 10。

若 x大于0：
  印 "x是正数"。
。

# if-else
定 y = -5。

若 y大于0：
  印 "y是正数"。
否则：
  印 "y不是正数"。
。

# if-elif-else
定 分数 = 85。

若 分数大于等于90：
  印 "优秀"。
否则若 分数大于等于80：
  印 "良好"。
否则若 分数大于等于60：
  印 "及格"。
否则：
  印 "不及格"。
。

# 嵌套条件
定 年龄 = 25。
定 会员 = 真。

若 年龄大于等于18：
  若 会员等于真：
    印 "欢迎会员！"。
  否则：
    印 "欢迎！"。
  。
否则：
  印 "未成年人请在家长陪同下使用"。
。

# 逻辑运算
定 a = 10。
定 b = 20。

若 a大于0且b大于0：
  印 "a和b都是正数"。
。

若 a大于100或b大于100：
  印 "a或b大于100"。
否则：
  印 "a和b都不大于100"。
。

# 比较运算
定 m = 5。
定 n = 5。

若 m等于n：
  印 "m等于n"。
。

若 m不等于n：
  印 "m不等于n"。
否则：
  印 "m等于n"。
。
