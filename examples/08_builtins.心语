# 心语编程语言 - 内置函数示例

# 打印函数
印 "=== 打印函数 ==="。
印 "你好，心语！"。
印 123， 456， 789。

# 类型转换
印 "=== 类型转换 ==="。
定 数字字符串 = "123"。
定 转换结果 = 转换为数字(数字字符串)。
印 "字符串转数字：" 转换结果。

定 数字 = 456。
印 "数字转字符串：" 转换为字符串(数字)。

# 类型检查
印 "=== 类型检查 ==="。
印 "123的类型：" 类型(123)。
印 "'心语'的类型：" 类型("心语")。
印 "【1，2，3】的类型：" 类型(【1，2，3】)。

# 列表操作
印 "=== 列表操作 ==="。
定 列表 = 【1， 2， 3， 4， 5】。
印 "列表：" 列表。
印 "长度：" 列表长度(列表)。
印 "求和：" 求和(列表)。
印 "最大值：" 最大值(列表)。
印 "最小值：" 最小值(列表)。
印 "平均值：" 求和(列表)除以列表长度(列表)。

# 排序
印 "=== 排序 ==="。
定 未排序 = 【5， 2， 8， 1， 9， 3】。
印 "排序前：" 未排序。
印 "升序：" 排序(未排序)。

# 范围生成
印 "=== 范围生成 ==="。
印 "范围(5)：" 范围(5)。
印 "范围(1， 6)：" 范围(1， 6)。
印 "范围(0， 10， 2)：" 范围(0， 10， 2)。

# 数学运算
印 "=== 数学运算 ==="。
印 "绝对值(-5)：" 绝对值(负5)。
印 "平方根(16)：" 平方根(16)。
印 "幂(2， 10)：" 幂(2， 10)。
印 "四舍五入(3.7)：" 四舍五入(3.7)。

# 字符串操作
印 "=== 字符串操作 ==="。
定 文本 = "  心语编程语言  "。
印 "原字符串：'" 文本 "'"。
印 "去空格：'" 文本.去空格() "'"。
印 "转大写：'" 文本.转大写() "'"。
印 "转小写：'" 文本.转小写() "'"。
印 "长度：" 列表长度(文本)。

# 布尔值
印 "=== 布尔值 ==="。
定 真 = 真。
定 假 = 假。
印 "真：" 真。
印 "假：" 假。
印 "真且假：" 真且假。
印 "真或假：" 真或假。
印 "非真：" 非真。
