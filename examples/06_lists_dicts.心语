# 心语编程语言 - 列表和字典示例

# 创建列表
定 数字列表 = 【1， 2， 3， 4， 5】。
定 字符串列表 = 【"苹果"， "香蕉"， "橙子"】。
印 "数字列表：" 数字列表。
印 "字符串列表：" 字符串列表。

# 访问列表元素
印 "第一个元素：" 数字列表[0]。
印 "第三个元素：" 数字列表[2]。
印 "最后一个元素：" 数字列表[负1]。

# 列表操作
定 列表 = 【10， 20， 30】。
印 "原列表：" 列表。

# 添加元素
列表.添加(40)。
印 "添加后：" 列表。

# 列表长度
印 "列表长度：" 列表长度(列表)。

# 列表求和
印 "列表求和：" 求和(列表)。

# 列表最大最小值
印 "最大值：" 最大值(列表)。
印 "最小值：" 最小值(列表)。

# 排序
定 未排序 = 【5， 2， 8， 1， 9】。
印 "排序前：" 未排序。
印 "排序后：" 排序(未排序)。

# 创建字典
定 学生 = ｛"姓名"： "张三"， "年龄"： 20， "成绩"： 85｝。
印 "学生信息：" 学生。

# 访问字典元素
印 "姓名：" 学生["姓名"]。
印 "年龄：" 学生["年龄"]。

# 修改字典
学生["年龄"] = 21。
印 "修改后的年龄：" 学生["年龄"]。

# 添加新键值对
学生["班级"] = "三年级"。
印 "添加班级后：" 学生。

# 字典操作
定 分数 = ｛"语文"： 90， "数学"： 85， "英语"： 88｝。
印 "各科分数：" 分数。

# 遍历字典
印 "遍历分数："。
遍历 科目 于 分数.键()：
  印 科目 "：" 分数[科目]。
。

# 嵌套结构
定 班级 = ｛
  "名称"： "一班"，
  "学生数"： 30，
  "平均分"： 87.5
｝。
印 "班级信息：" 班级。
