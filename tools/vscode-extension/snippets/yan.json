{
  "定义变量": {
    "prefix": "定义",
    "body": [
      "定义 ${1:变量名} = ${2:值}。"
    ],
    "description": "定义变量"
  },
  "定义函数": {
    "prefix": "函数",
    "body": [
      "函数 ${1:函数名}：",
      "  参数 ${2:参数}。",
      "  ${3:函数体}。",
      "  返回 ${4:结果}。"
    ],
    "description": "定义函数"
  },
  "条件语句": {
    "prefix": "如果",
    "body": [
      "如果 ${1:条件} 那么",
      "  ${2:分支1}。",
      "否则",
      "  ${3:分支2}。"
    ],
    "description": "条件语句"
  },
  "遍历循环": {
    "prefix": "循环",
    "body": [
      "循环 ${1:变量} 遍历 ${2:列表}：",
      "  ${3:循环体}。"
    ],
    "description": "遍历循环"
  },
  "条件循环": {
    "prefix": "当满足",
    "body": [
      "当满足 ${1:条件}：",
      "  ${2:循环体}。"
    ],
    "description": "条件循环"
  },
  "重复执行": {
    "prefix": "重复",
    "body": [
      "重复 ${1:次数} 次数：",
      "  ${2:循环体}。"
    ],
    "description": "重复执行"
  },
  "打印语句": {
    "prefix": "打印",
    "body": [
      "打印 \"${1:内容}\"。"
    ],
    "description": "打印语句"
  },
  "输入语句": {
    "prefix": "输入",
    "body": [
      "定义 ${1:变量} = 输入 \"${2:提示}\"。"
    ],
    "description": "输入语句"
  },
  "列表定义": {
    "prefix": "列表",
    "body": [
      "定义 ${1:列表名} = [${2:元素1}, ${3:元素2}, ${4:元素3}]。"
    ],
    "description": "列表定义"
  },
  "字典定义": {
    "prefix": "字典",
    "body": [
      "定义 ${1:字典名} = {",
      "  \"${2:键1}\": ${3:值1},",
      "  \"${4:键2}\": ${5:值2}",
      "}。"
    ],
    "description": "字典定义"
  },
  "数学轨": {
    "prefix": "$(",
    "body": [
      "$(${1:数学表达式})"
    ],
    "description": "数学轨表达式"
  },
  "Python轨": {
    "prefix": "{{",
    "body": [
      "{{${1:Python代码}}}"
    ],
    "description": "Python轨代码"
  },
  "SQL轨": {
    "prefix": "SQL",
    "body": [
      "SQL\"${1:SQL查询}\""
    ],
    "description": "SQL轨查询"
  },
  "Shell轨": {
    "prefix": ">(",
    "body": [
      ">(${1:Shell命令})"
    ],
    "description": "Shell轨命令"
  },
  "导入模块": {
    "prefix": "导入",
    "body": [
      "导入 ${1:模块名}。"
    ],
    "description": "导入模块"
  },
  "尝试捕获": {
    "prefix": "尝试",
    "body": [
      "尝试：",
      "  ${1:代码}。",
      "捕获：",
      "  ${2:处理}。"
    ],
    "description": "异常处理"
  }
}
